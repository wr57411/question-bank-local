{
  "name": "question-bank-local",
  "version": "1.0.0",
  "description": "本地题库管理应用 - 无需联网",
  "scripts": {
    "dev": "npx serve www",
    "build": "echo 'Static app, no build needed'",
    "test:e2e:pw": "playwright test",
    "test:e2e:pw:debug": "playwright test --debug",
    "test:e2e:pw:ui": "playwright test --ui",
    "validate:e2e": "node scripts/validate-e2e.js",
    "cap:init": "npx cap init question-bank-local com.questionbank.local --web-dir www",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:run:android": "npx cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/browser": "^6.0.6",
    "@capacitor/camera": "^6.1.3",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/ios": "^6.2.1",
    "jspdf": "^2.5.1",
    "localforage": "^1.10.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@playwright/test": "^1.58.2",
    "serve": "^14.2.0",
    "typescript": "^6.0.2"
  }
}
